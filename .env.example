# Local Docker PostgreSQL
POSTGRES_USER=payload
POSTGRES_PASSWORD=payload
POSTGRES_DB=hpttech_payload
DATABASE_URI=postgres://payload:payload@127.0.0.1:5433/hpttech_payload

# Payload
PAYLOAD_SECRET=dev-payload-secret-change-me

# Production database on Vercel should use Neon, for example:
# DATABASE_URI=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Cloudflare R2 / S3-compatible storage
# Required on Vercel because serverless local uploads are not persistent.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto

# Other
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
