# Local Docker PostgreSQL
POSTGRES_USER=payload
POSTGRES_PASSWORD=payload
POSTGRES_DB=hpttech_payload
DATABASE_URI=postgres://payload:payload@127.0.0.1:5433/hpttech_payload

# Payload
PAYLOAD_SECRET=dev-payload-secret-change-me
# Set true only when you intentionally want Payload to push/update Postgres schema.
PAYLOAD_DB_PUSH=false
# Vercel production fails loudly on Payload read errors by default.
# Set true to force strict reads locally, or false to temporarily disable strict mode.
PAYLOAD_STRICT_READS=
# Emergency-only switch: allows empty fallback data even on production.
PAYLOAD_ALLOW_EMPTY_FALLBACK=false
PAYLOAD_DEBUG_READ_ERRORS=false

# Production database on Vercel should use Neon, for example:
# DATABASE_URI=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# Cloudflare R2 / S3-compatible storage
# Required on Vercel because serverless local uploads are not persistent.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
# Public R2 bucket URL or custom domain, e.g. https://pub-xxxx.r2.dev
R2_PUBLIC_URL=

# Other
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_SCRAPER_TIMEOUT_MS=45000
CONTACT_WEBHOOK_URL=
CONTACT_WEBHOOK_SECRET=

# MISA AMIS connection test
# Ask MISA for the exact base URL and endpoint path for the AMIS module you use.
MISA_BASE_URL=https://actapp.misa.vn
MISA_TEST_PATH=/
MISA_APP_ID=
MISA_CONNECTION_CODE=
MISA_AUTH_SCHEME=Bearer
MISA_AUTH_HEADER=Authorization
MISA_COMPANY_ID=
MISA_COMPANY_HEADER=X-Company-Id
MISA_SYNC_SECRET=

# Product CSV import/export.
# Required in production. Local dev allows requests when this is empty.
PRODUCT_IMPORT_EXPORT_SECRET=

# Product scraper MVP
SCRAPER_API_SECRET=
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_SEARCH_TIMEOUT_MS=20000
SCRAPER_ALLOWED_DOMAINS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PRODUCT_THREAD_ID=
TELEGRAM_MESSAGE_THREAD_ID=
TELEGRAM_TIMEOUT_MS=10000
SCRAPER_DELAY_MS=3000
SCRAPER_DB_TIMEOUT_MS=5000
SCRAPER_MAX_HTML_CHARS=60000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_IDLE_TIMEOUT_MS=8000
GEMINI_SEARCH_TIMEOUT_MS=30000
GEMINI_ENRICH_TIMEOUT_MS=30000
SCRAPER_FETCH_TIMEOUT_MS=30000
